<?php
require_once 'db_connect.php';
$conn = db_connect();
$zprava = '';
 
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['akce'])) {
    if ($_POST['akce'] === 'insert') {
        $stmt = $conn->prepare("INSERT INTO tabulka1 (jmeno, vek) VALUES (?, ?)");
        $stmt->bind_param("si", $_POST['jmeno'], $_POST['vek']);
        $stmt->execute();
        $id = $conn->insert_id;
        $stmt2 = $conn->prepare("INSERT INTO tabulka2 (id, adresa, telefon) VALUES (?, ?, ?)");
        $stmt2->bind_param("iss", $id, $_POST['adresa'], $_POST['telefon']);
        $stmt2->execute();
        $zprava = "Zaznam byl uspesne pridan (ID: $id).";
 
    } elseif ($_POST['akce'] === 'delete') {
        $id = (int)$_POST['id'];
        $conn->query("DELETE FROM tabulka1 WHERE id = $id");
        $conn->query("DELETE FROM tabulka2 WHERE id = $id");
        $zprava = "Zaznam ID $id byl smazan.";
 
    } elseif ($_POST['akce'] === 'update') {
        $id = (int)$_POST['id'];
        $stmt = $conn->prepare("UPDATE tabulka1 SET jmeno=?, vek=? WHERE id=?");
        $stmt->bind_param("sii", $_POST['jmeno'], $_POST['vek'], $id);
        $stmt->execute();
        $stmt2 = $conn->prepare("UPDATE tabulka2 SET adresa=?, telefon=? WHERE id=?");
        $stmt2->bind_param("ssi", $_POST['adresa'], $_POST['telefon'], $id);
        $stmt2->execute();
        $zprava = "Zaznam ID $id byl uspesne upraven.";
    }
}
 
if ($zprava) echo "<div class='zprava'>✅ $zprava</div>";
?>
 
<h2>Pridat zaznam</h2>
