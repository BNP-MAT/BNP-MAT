        <input type="text" name="adresa" placeholder="Adresa" required>
        <input type="text" name="telefon" placeholder="Telefon" required>
        <button type="submit">Pridat</button>
    </form>
</div>
 
<h2>Vyhledat zaznamy</h2>
<div class="formular">
    <form method="get">
        <input type="text" name="jmeno" placeholder="Cast jmena" value="<?php echo htmlspecialchars(isset($_GET['jmeno']) ? $_GET['jmeno'] : ''); ?>">
        <input type="text" name="adresa" placeholder="Cast adresy" value="<?php echo htmlspecialchars(isset($_GET['adresa']) ? $_GET['adresa'] : ''); ?>">
        <button type="submit">Hledat</button>
        <a href="tables.php"><button type="button">Zrusit filtr</button></a>
    </form>
</div>
 
<?php
$where = array();
$params = array();
$types = '';
if (!empty($_GET['jmeno']))  { $where[] = "t1.jmeno LIKE ?";  $params[] = '%'.$_GET['jmeno'].'%';  $types .= 's'; }
if (!empty($_GET['adresa'])) { $where[] = "t2.adresa LIKE ?"; $params[] = '%'.$_GET['adresa'].'%'; $types .= 's'; }
 
$sql = "SELECT t1.id, t1.jmeno, t1.vek, t2.adresa, t2.telefon FROM tabulka1 t1 LEFT JOIN tabulka2 t2 ON t1.id = t2.id";
if ($where) $sql .= " WHERE " . implode(" AND ", $where);
 
$stmt = $conn->prepare($sql);
if ($params) {
    if (count($params) === 1) {
        $stmt->bind_param($types, $params[0]);
    } else {
        $stmt->bind_param($types, $params[0], $params[1]);
    }
}
$stmt->execute();
$result = $stmt->get_result();
?>
 
<table>
    <tr><th>ID</th><th>Jmeno</th><th>Vek</th><th>Adresa</th><th>Telefon</th><th>Akce</th></tr>
    <?php while ($r = $result->fetch_assoc()): ?>
    <tr>
        <td><?php echo $r['id']; ?></td>
        <td><?php echo htmlspecialchars($r['jmeno']); ?></td>
        <td><?php echo $r['vek']; ?></td>
        <td><?php echo htmlspecialchars(isset($r['adresa']) ? $r['adresa'] : 'Neni'); ?></td>
        <td><?php echo htmlspecialchars(isset($r['telefon']) ? $r['telefon'] : 'Neni'); ?></td>
        <td>
            <form method="post" style="display:inline" onsubmit="return confirm('Smazat zaznam?')">
                <input type="hidden" name="akce" value="delete">
                <input type="hidden" name="id" value="<?php echo $r['id']; ?>">
                <button class="red" type="submit">Smazat</button>
            </form>
            <button onclick="document.getElementById('edit-<?php echo $r['id']; ?>').style.display='block'">Upravit</button>
        </td>
    </tr>
    <tr id="edit-<?php echo $r['id']; ?>" style="display:none; background:#fffbeb">
        <td colspan="6">
            <form method="post">
                <input type="hidden" name="akce" value="update">
                <input type="hidden" name="id" value="<?php echo $r['id']; ?>">
                <input type="text" name="jmeno" value="<?php echo htmlspecialchars($r['jmeno']); ?>" required>
                <input type="number" name="vek" value="<?php echo $r['vek']; ?>" required>
                <input type="text" name="adresa" value="<?php echo htmlspecialchars(isset($r['adresa']) ? $r['adresa'] : ''); ?>" required>
                <input type="text" name="telefon" value="<?php echo htmlspecialchars(isset($r['telefon']) ? $r['telefon'] : ''); ?>" required>
                <button type="submit">Ulozit</button>
            </form>
        </td>
    </tr>
    <?php endwhile; ?>
</table>
 
